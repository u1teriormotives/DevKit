{
  "$": {
    "useHttps": false,
    "useHttp2": false,
    "httpsConfig": {
      "key": "relative_path.key",
      "cert": "relative_path.crt"
    },
    "port": 8080,
    "ratelimiting": {
      "enabled": false,
      "max-requests": 200,
      "timeframe-m": 30
    }
  },
  "/": [
    {
      "requestType": "GET",
      "file": "index.html",
      "contentType": "text/html",
      "externalFunction": false
    },
    {
      "requestType": "POST",
      "file": "test.js",
      "externalFunction": true
    }
  ]
}
